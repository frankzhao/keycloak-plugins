# Copy this file to .env and fill in the values for your local environment.
# python-dotenv will load .env automatically when app.py is run directly.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   source .venv/bin/activate
#   flask run

# Flask session signing key — change this to a random value in any non-dev environment
SECRET_KEY=dev-secret

# Keycloak connection details
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=juju
KEYCLOAK_CLIENT_ID=test-app

# Client secret configured in the Keycloak client settings
# (Clients > test-app > Credentials > Client secret)
KEYCLOAK_CLIENT_SECRET=secret

# Port the Flask dev server listens on (default: 5000)
PORT=5000

# Set to "true" to enable Flask debug mode / auto-reload
FLASK_DEBUG=true
